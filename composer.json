{
    "name": "mundophpbb/supporttriage",
    "type": "phpbb-extension",
    "description": "Support Triage Assistant for phpBB. Helps moderators and support teams efficiently categorize, tag and manage technical support topics.",
    "homepage": "https://github.com/mundophpbb/supporttriage",
    "version": "3.4.8",
    "license": "GPL-2.0-only",
    "authors": [
        {
            "name": "Chico Gois",
            "homepage": "https://github.com/mundophpbb",
            "role": "Developer"
        }
    ],
    "keywords": [
        "phpbb",
        "extension",
        "support",
        "triage",
        "moderation",
        "assistant"
    ],
    "support": {
        "issues": "https://github.com/mundophpbb/supporttriage/issues",
        "source": "https://github.com/mundophpbb/supporttriage"
    },
    "require": {
        "php": ">=7.1",
        "composer/installers": "^1.0 || ^2.0"
    },
    "require-dev": {
        "phpbb/epv": "dev-master"
    },
    "extra": {
        "display-name": "Support Triage",
        "soft-require": {
            "phpbb/phpbb": ">=3.3.0,<4.0.0@dev"
        },
        "version-check": {
            "host": "raw.githubusercontent.com",
            "directory": "mundophpbb/supporttriage/master",
            "filename": "version_check.json",
            "ssl": true
        }
    }
}
